---
import { stripStega } from '@datocms/astro';
import { type DastroTypes } from '../../core/lib-types.ts';
import type { ClassValue } from '../component.types.ts';
import { contentLinkAttrs } from '../content-link/content-link-attrs.ts';
import {
  withUrlExtras,
  type QueryParamsInput,
} from '../../util/route.util.ts';

export interface Props<T extends DastroTypes = DastroTypes> {
  // "record" is passed in when using inside StructuredText
  record: T['RecordLinkFragment'];
  id?: string;
  target?: string;
  linkTitle?: string;
  class?: ClassValue;
  query?: QueryParamsInput;
  hash?: string;

  [key: string]: unknown;
}

const {
  record,
  id,
  target = '_self',
  class: classNames,
  linkTitle = '',
  query,
  hash,
  ...rest
} = Astro.props;

const { resolveRecordUrl } = Astro.locals.dastro.routing();

const resolvedUrl = resolveRecordUrl(record, Astro.locals.locale);
const href =
  resolvedUrl !== null ? withUrlExtras(resolvedUrl, { query, hash }) : null;
---

{
  record?.__typename && (
    <a
      id={stripStega(id)}
      class="link"
      class:list={stripStega(classNames)}
      data-astro-prefetch
      href={href}
      target={stripStega(target)}
      title={stripStega(linkTitle)}
      {...contentLinkAttrs({ boundary: true })}
      {...rest}
    >
      <slot>{record.title || 'Untitled'}</slot>
    </a>
  )
}
