---
import type { ClassValue, VideoAssetData } from '../component.types';

interface Props {
  data: VideoAssetData;
  class?: ClassValue;
  aspectRatio?: number;
  videoResolution?: 'low' | 'medium' | 'high';
  posterMaxWidth?: number;
}

const {
  data,
  videoResolution,
  aspectRatio,
  posterMaxWidth = 800,
  class: classNames,
  ...rest
} = Astro.props;

const video = data.video;

function getVideoUrl(): string | null {
  switch (videoResolution) {
    case 'low':
      return data.video?.urlLowRes ?? null;
    case 'medium':
      return data.video?.urlMediumRes ?? null;
    case 'high':
    default:
      return data.video?.urlHighRes ?? null;
  }
}

function getPosterUrl(): string | undefined {
  if (!video?.thumbnailUrl) {
    return undefined;
  }

  const width = video.width
    ? Math.min(video.width, posterMaxWidth)
    : posterMaxWidth;

  const url = new URL(video.thumbnailUrl.replace(/\.jpg(\?|$)/, '.webp$1'));
  url.searchParams.set('time', '0');
  url.searchParams.set('width', String(width));

  return url.toString();
}
---

<div
  class="video-asset"
  class:list={classNames}
  {...rest}
  style={{ aspectRatio }}
>
  {
    video && (
      <video
        class="video"
        width={video.width}
        height={video.height}
        autoplay
        muted
        loop
        playsinline
        poster={getPosterUrl()}
      >
        <source src={getVideoUrl()} type="video/mp4" />
        Video is not supported
      </video>
    )
  }
</div>

